# ─────────────────────────────────────────────────────────────────────────────
# Stage 3 — Decentralised Thinking Agent + Observability Control Plane
# Copy to `.env` and fill in real values. `uv run` does NOT auto-load .env;
# load it per terminal (see README → Running).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (agent_client + analysis_dashboard) ──────────────────────────────────
# Groq powers both the operational ReAct loop and the analysis agent.
GROQ_API_KEY="gsk_..."

# ── Web grounding (agent_client + mcp_server CRAG fallback) ───────────────────
TAVILY_API_KEY="tvly-..."

# ── MCP transport ─────────────────────────────────────────────────────────────
MCP_SERVER_URL="http://localhost:8000/mcp"

# ── Embedded vector log store (Stage 3) ───────────────────────────────────────
# Local on-disk SQLite file persisting hierarchical, vector-indexed log traces.
MCP_LOG_DB_PATH="mcp_agent_log.db"
# Flat dual-stream log file (Stage 2 carry-over, renamed for Stage 3).
MCP_FLAT_LOG="mcp_agent_system.log"
# Set 0 to run a single demo turn instead of the multi-turn trace.
MCP_MULTI_TURN="1"

# Embeddings are LOCAL (fastembed BAAI/bge-small-en-v1.5, 384-dim) — no key
# required. No external embedding endpoint, so no broken connection strings.

# ── Neo4j Aura DB (analysis_dashboard knowledge-graph projection) ─────────────
# Create a free instance at https://neo4j.com/product/auradb/ and paste the
# bolt+routing URI shown on the instance card. The graph mapper degrades
# gracefully (reports "not_configured") if these are left blank.
NEO4J_URI="neo4j+s://<your-instance>.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="<your-aura-password>"
NEO4J_DATABASE="neo4j"

# ── Analysis agent tuning (optional) ──────────────────────────────────────────
ANALYSIS_MODEL="llama-3.3-70b-versatile"
ANALYSIS_LOG="analysis_agent.log"
CHART_DIR="charts"
